APP_NAME="UUT PRF"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=uut_prf_dev
DB_USERNAME=uut_user
DB_PASSWORD=uut_password

SESSION_DRIVER=file
QUEUE_CONNECTION=database
CACHE_STORE=file

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
# QUEUE_CONNECTION=redis

# CACHE_STORE=redis
CACHE_PREFIX=uut_prf_cache

# REDIS_CLIENT=phpredis
# REDIS_HOST=redis
# REDIS_PASSWORD=null
# REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@uut-prf.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=uut-prf-dev
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/uut-prf-dev

CLICKPESA_BASE_URL=
CLICKPESA_API_KEY=
CLICKPESA_SECRET_KEY=
CLICKPESA_WEBHOOK_SECRET=
CLICKPESA_CALLBACK_URL=
CLICKPESA_CURRENCY=TZS

VITE_APP_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:3000